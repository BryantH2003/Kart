# .env.example — copy to .env.local and fill in real values
# This file is safe to commit (no real secrets)

# Supabase — get from Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — bypasses RLS
SUPABASE_PROJECT_ID=              # your project reference ID (e.g. lwkhnwslotobwyoofnwp)
SUPABASE_DB_PASSWORD=             # used by Supabase CLI for db push/reset

# CheapShark API requires no key — no configuration needed

# Resend — get from resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=                # e.g. alerts@yourdomain.com (or onboarding@resend.dev for sandbox)

# Groq — get from console.groq.com → API Keys
GROQ_API_KEY=

# Unsubscribe token signing (CAN-SPAM compliance)
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# Cron job authentication — verified by the poll-prices Edge Function
# Generate with: openssl rand -hex 32  (then also: supabase secrets set CRON_SECRET=<value>)
CRON_SECRET=
